# ───── MongoDB ─────
MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/?appName=YourApp

# ───── JWT ─────
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ───── Cloudinary ─────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
MEDIA_PRIVATE_MODE=false
ENABLE_WATERMARK=true

# ───── AI Service ─────
AI_SERVICE_URL=http://localhost:8000

# ───── Redis / BullMQ ─────
REDIS_URL=redis://localhost:6379
ENABLE_QUEUE=false

# ───── Google OAuth ─────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# ───── App ─────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SnapFind AI

# ───── Rate Limiting ─────
FACE_SCAN_RATE_LIMIT=5
FACE_SCAN_RATE_WINDOW_MS=60000
RATE_LIMIT_BACKEND=memory

# ───── Plan Limits (Free) ─────
FREE_EVENT_LIMIT=3
FREE_PHOTO_LIMIT=50
FREE_STORAGE_MB=500
FREE_DAILY_DOWNLOAD=20
FREE_FACE_SCANS_PER_MIN=5

# ───── Plan Limits (Pro) ─────
PRO_STORAGE_MB=10240
PRO_PHOTO_LIMIT=5000
PRO_FACE_SCANS_PER_MIN=60
